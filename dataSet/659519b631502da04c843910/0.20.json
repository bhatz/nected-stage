  "description": "",
  "query": "select customer_name, customer_id as customerNumber, category_name as productLine, name as productName, sum(customer_score) as customerScore, MIN(price) as price,  MIN ((tmp.quantity_order)*100/(tmp.quantity_in_stock+tmp.quantity_order)) as inventory_booked_perc,  sum(tmp.total_order) as order_volume,  sum(tmp.quantity_order) as order_count from  (SELECT o.id, c.name as customer_name, o.created_at, o.customer_id, c.customer_score, od.product_id, od.quantity_order, od.price_each, c.credit_limit, pl.category_name,  p.name, p.quantity_in_stock, p.price, (od.quantity_order*od.price_each) as total_order FROM ecomm.orders o JOIN ecomm.order_details od ON o.id = od.order_id JOIN ecomm.products p ON od.product_id = p.id JOIN ecomm.customers c ON o.customer_id = c.id JOIN ecomm.product_lines pl ON p.category_id = pl.id) tmp group by productName, productLine, customerNumber, customer_name;",
