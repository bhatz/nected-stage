  },
  "description": "",
  "query": "select customer_name, customer_id as customerNumber, category_name as asset_category, name as asset_name, sum(customer_score) as customerScore,\nMIN(price) as price, \nMIN ((tmp.quantity_order)*100/(tmp.quantity_in_stock+tmp.quantity_order)) as xrr, \nsum(tmp.total_order) as trade_volume, \nsum(tmp.quantity_order) as trade_quantity from \n(SELECT o.id, c.name as customer_name,\no.created_at, o.customer_id, c.customer_score,\nod.product_id, od.quantity_order, od.price_each, c.credit_limit, pl.category_name, \np.name, p.quantity_in_stock, p.price, (od.quantity_order*od.price_each) as total_order\nFROM fintech.trades o\nJOIN fintech.trade_details od ON o.id = od.order_id\nJOIN fintech.assets p ON od.product_id =  p.id\nJOIN fintech.traders c ON o.customer_id = c.id\nJOIN fintech.asset_categories pl ON p.category_id = pl.id) tmp\ngroup by asset_name, asset_category, customerNumber, customer_name;",
